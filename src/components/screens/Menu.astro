---
---

<div id="screen-menu" class="screen">
  <div class="menu-header">
    <div class="deco-hearts">♡ ✦ ♥ ✦ ♡</div>
    <h1>Birthday<br/>Surprise Box</h1>
    <p>✦ tap to explore ✦</p>
  </div>
  <div class="bento-grid" id="bento-grid">
    <!-- 1: Replay (new) -->
    <div class="bento-card" data-section="replay">
      <div class="sparkle-glow"></div>
      <span class="card-icon">🔄</span>
      <span class="card-label">Replay Story</span>
      <span class="card-sub">experience it again</span>
      <span class="card-deco">💫</span>
    </div>
    <!-- 2: Stories -->
    <div class="bento-card" data-section="stories">
      <div class="sparkle-glow"></div>
      <span class="card-icon">💬</span>
      <span class="card-label">Stories</span>
      <span class="card-sub">sweet moments</span>
      <span class="card-deco">📖</span>
      <span class="float-bubble" style="bottom:15%;left:8%;animation-delay:1s;">💬</span>
    </div>
    <!-- 3: Journey (full-width, horizontal) -->
    <div class="bento-card" data-section="journey">
      <div class="sparkle-glow"></div>
      <span class="card-icon">🗺️</span>
      <div style="text-align:left;">
        <span class="card-label">Journey</span>
        <span class="card-sub">our story board game</span>
      </div>
      <span class="card-deco">🎲</span>
      <span class="float-bubble" style="top:15%;left:20%;animation-delay:0.8s;">📍</span>
      <span class="float-bubble" style="bottom:10%;right:18%;animation-delay:1.4s;">❤️</span>
    </div>
    <!-- 4: Album -->
    <div class="bento-card" data-section="album">
      <div class="sparkle-glow"></div>
      <span class="card-icon">🖼️</span>
      <span class="card-label">Album</span>
      <span class="card-sub">memory exhibition</span>
      <span class="card-deco">🎨</span>
      <span class="float-bubble" style="bottom:20%;right:10%;animation-delay:0.6s;">📸</span>
    </div>
    <!-- 5: Postcard -->
    <div class="bento-card" data-section="postcard">
      <div class="sparkle-glow"></div>
      <span class="card-icon">💌</span>
      <span class="card-label">Post Card</span>
      <span class="card-sub">a letter for you</span>
      <span class="card-deco">✉️</span>
      <span class="float-bubble" style="top:12%;left:10%;animation-delay:1.1s;">💕</span>
    </div>
    <!-- 6: Secret -->
    <div class="bento-card" data-section="secret">
      <div class="sparkle-glow"></div>
      <span class="card-icon">🔐</span>
      <span class="card-label">Secret Gallery</span>
      <span class="card-sub">something special</span>
      <span class="card-deco">✨</span>
      <span class="float-bubble" style="bottom:18%;right:8%;animation-delay:0.4s;">🔑</span>
    </div>
    <!-- 7: Surprise -->
    <div class="bento-card" data-section="surprise">
      <div class="sparkle-glow"></div>
      <span class="card-icon">🎁</span>
      <span class="card-label">Surprise Box</span>
      <span class="card-sub">random treats</span>
      <span class="card-deco">🎊</span>
    </div>
    <!-- 8: Daily -->
    <div class="bento-card" data-section="daily">
      <div class="sparkle-glow"></div>
      <span class="card-icon">📅</span>
      <span class="card-label">Love Notes</span>
      <span class="card-sub">27 days of love</span>
      <span class="card-deco">💕</span>
    </div>
    <!-- 9: Wish (full-width, horizontal) -->
    <div class="bento-card" data-section="wish">
      <div class="sparkle-glow"></div>
      <span class="card-icon">⭐</span>
      <div style="text-align:left;">
        <span class="card-label">Wish Wall</span>
        <span class="card-sub">make a wish</span>
      </div>
      <span class="card-deco">🌈</span>
    </div>
  </div>
</div>
