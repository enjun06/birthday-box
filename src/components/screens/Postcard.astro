---
import BackButton from '../shared/BackButton.astro';
---

<div id="screen-postcard" class="screen">
  <BackButton />
  <div class="section-title">✦ Post Card ✦</div>
  <div class="section-sub">a letter written just for you</div>
  <div class="postcard-scene">
    <div class="postcard-deco-frames" id="postcard-deco-frames"></div>
    <div class="postcard-main" id="postcard-main">
      <div class="postcard-front" id="postcard-front">
        <div class="front-icon" id="postcard-icon">💌</div>
        <div class="front-label" id="postcard-label">For you, my love</div>
        <div class="front-hint">✦ tap to open ✦</div>
      </div>
      <div class="postcard-back">
        <div class="letter-text" id="letter-text"></div>
      </div>
    </div>
  </div>
</div>
