---
import BackButton from '../shared/BackButton.astro';
---

<div id="screen-secret" class="screen">
  <BackButton />
  <div class="section-title">✦ Secret ✦</div>
  <div class="section-sub">this room is only for someone special</div>
  <div class="secret-lock" id="secret-lock">
    <div class="lock-icon">🔒</div>
    <div class="lock-text">This room is only for someone special.</div>
    <input class="lock-input" id="lock-input" type="text" placeholder="Enter password…" autocomplete="off" />
    <button class="lock-btn" id="lock-btn">Unlock</button>
    <div class="lock-hint" id="lock-hint">Try the word that explains everything.</div>
  </div>
  <div class="secret-gallery" id="secret-gallery">
    <div class="gallery-scatter" id="gallery-scatter"></div>
    <div class="playlist-section">
      <div class="playlist-title">🎵 Our Playlist</div>
      <div class="playlist-embed">
        <iframe style="border-radius:12px" src="https://open.spotify.com/embed/playlist/6durrIxUdbjRJ171mwRJtP?utm_source=generator" width="100%" height="152" frameBorder="0" allowfullscreen="" allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture" loading="lazy"></iframe>
      </div>
    </div>
    <div class="scratch-frame" id="scratch-frame">
      <div class="scratch-bg">
        <div class="scratch-label">Erase me slowly</div>
        <div class="scratch-hint">✦ swipe to reveal ✦</div>
      </div>
      <canvas class="scratch-canvas" id="scratch-canvas"></canvas>
      <div class="scratch-reveal" id="scratch-reveal">
        <div class="reveal-icon">💖</div>
        <div class="reveal-quote">"Of all the memories here, this one is my favorite…<br/>because it reminds me how <span class="highlight">lucky</span> I am to love you."</div>
      </div>
    </div>
    <div class="scratch-progress" id="scratch-progress">0% revealed</div>
  </div>
</div>
